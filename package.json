{
  "name": "mindwtr-web",
  "private": true,
  "type": "module",
  "workspaces": [
    "landing"
  ],
  "scripts": {
    "assets:sync": "bun scripts/sync-assets.mjs",
    "landing:dev": "bun run --cwd landing dev",
    "landing:build": "bun run --cwd landing build",
    "docs:dev": "bun run --cwd docs dev",
    "docs:build": "bun run --cwd docs docs:build",
    "check:secrets": "bun scripts/check-secrets.mjs",
    "check": "bun run check:secrets && bun run landing:build && bun run docs:build"
  }
}
